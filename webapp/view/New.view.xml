<veera:View
    xmlns:core="sap.ui.core"
    xmlns:veera="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns="sap.ui.table"
    controllerName="project1.controller.New"
>
    <m:Page
        id="detailPage"
        title="Title"
        navButtonPress="onNavPress"
        showNavButton="true"
    >
        <m:content>
            <m:Text
                id="objectHeader"
                text="Welcome to Second View"
            />
            <fb:FilterBar
                reset="onReset"
                search="onSearchFilterbar"
                showRestoreButton="true"
                showClearOnFB="true"
                filterBarExpanded="false"
                id="userFilterBar"
                clear="onClear"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        visibleInFilterBar="true"
                        id="filter1"
                        groupName="filterGroup1"
                        name="A"
                        label="StartDate"
                    >
                        <fb:control>
                            <m:DatePicker
                                id="DP1"
                                placeholder="Enter Date"
                                change="handleChange"
                                valueFormat="YYYY-MM-DD"
                                class="sapUiSmallMarginBottom"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        visibleInFilterBar="true"
                        id="filter2"
                        groupName="filterGroup1"
                        name="B"
                        label="EndDate"
                    >
                        <fb:control>
                            <m:DatePicker
                                id="DP2"
                                placeholder="Enter Date"
                                change="handleChange"
                                valueFormat="YYYY-MM-DD"
                                class="sapUiSmallMarginBottom"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                    <fb:FilterGroupItem
                        visibleInFilterBar="true"
                        id="filter3"
                        groupName="filterGroup1"
                        name="C"
                        label="Sub Account Name"
                    >
                        <fb:control>
                            <m:Input
                                id="input2"
                                class="sapUiSmallMarginBottom"
                            />
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>

            <Table
                id="idSubaccountTable"
                rows="{/content}"
                visibleRowCount="10"
                selectionMode="Single"
            >
                <extension>
                    <m:OverflowToolbar
                        id="tableToolbarId"
                        style="Clear"
                    >
                        <m:Title
                            id="title"
                            text="Sub Account Details"
                        />
                    </m:OverflowToolbar>
                </extension>

                <columns>
                    <Column
                        id="column3"
                        width="11rem"
                        hAlign="End"
                    >
                        <m:Label
                            id="label3"
                            text="Sub Account Name"
                        />
                        <template>
                            <m:Label
                                id="label4"
                                text="{subaccountName}"
                            />
                        </template>
                    </Column>

                    <Column
                        id="column9"
                        width="7rem"
                    >
                        <m:Label
                            id="label10"
                            text="Service Name"
                        />
                        <template>
                            <m:Text
                                id="checkbox"
                                text="{serviceName}"
                            />
                        </template>
                    </Column>

                    <Column
                        id="column11"
                        width="6rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label12"
                            text="Plan Name"
                        />
                        <template>
                            <m:Text
                                id="icon"
                                text="{planName}"
                            />
                        </template>
                    </Column>
                    <Column
                        id="column12"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label13"
                            text="Measure Id"
                        />
                        <template>
                            <m:Text
                                id="datepicker"
                                text="{measureId}"
                            />
                        </template>
                    </Column>
                    <Column
                        id="column13"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label14"
                            text="Metric Name"
                        />
                        <template>
                            <m:Text
                                id="text4"
                                text="{metricName}"
                            />
                        </template>
                    </Column>

                    <Column
                        id="column18"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label19"
                            text="Data Center Name"
                        />
                        <template>
                            <m:Text
                                id="datepicker4"
                                text="{dataCenterName}"
                            />
                        </template>
                    </Column>
                    <Column
                        id="column20"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label21"
                            text="Usage"
                        />
                        <template>
                            <m:Text
                                id="datepicker5"
                                text="{usage}"
                            />
                        </template>
                    </Column>
                    <Column
                        id="column21"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label22"
                            text="Cost"
                        />
                        <template>
                            <m:Text
                                id="datepicker6"
                                text="{cost}({currency})"
                            />
                        </template>
                    </Column>
                    <Column
                        id="column22"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label23"
                            text="Start Iso Date"
                        />
                        <template>
                            <m:Text
                                id="datepicker7"
                                text="{startIsoDate}"
                            />
                        </template>
                    </Column>
                    <Column
                        id="column23"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label24"
                            text="End Iso Date"
                        />
                        <template>
                            <m:Text
                                id="datepicker8"
                                text="{endIsoDate}"
                            />
                        </template>
                    </Column>

                    <Column
                        id="column25"
                        width="11rem"
                        hAlign="Center"
                    >
                        <m:Label
                            id="label26"
                            text="CRM Sku"
                        />
                        <template>
                            <m:Text
                                id="datepicker10"
                                text="{crmSku}"
                            />
                        </template>
                    </Column>
                </columns>
            </Table>
        </m:content>
       
            	<m:Button
			        text="Dialog"
			        width="230px"
			        press="onPressDialog"
			        class="sapUiSmallMarginBottom" />
                <m:Button
			        text="Edit Employee Detail "
			        width="230px"
			        press="onPressEditDialog"
			        class="sapUiSmallMarginBottom" />
    </m:Page>
</veera:View>